# ─────────────────────────────────────────────────────────────────────
# HomiHire Admin Panel — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────────

# ── Backend API URL ──────────────────────────────────────────────────
# When running backend LOCALLY on same machine → leave blank or use:
# VITE_API_BASE_URL=http://localhost:5000
#
# When backend is on a DIFFERENT machine on same network (LAN), use:
# VITE_API_BASE_URL=http://192.168.X.X:5000   ← replace with Sufyan's LAN IP
#
# When using ngrok tunnel, use:
# VITE_API_BASE_URL=https://xxxx-xx-xx.ngrok-free.app
#
# NOTE: If this is not set at all, the Vite dev proxy will automatically
# forward all /api/* calls to http://localhost:5000 (same machine default).
VITE_API_BASE_URL=http://localhost:5000
